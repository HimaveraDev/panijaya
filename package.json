{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "serve": "nodemon --watch .env --watch app --watch routes --ext php,env --exec \"php artisan serve\"",
        "start": "concurrently \"npm run dev\" \"npm run serve\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": ">=1.11.0 <=1.14.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "nodemon": "^3.1.14",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
